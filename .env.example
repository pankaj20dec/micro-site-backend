PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fipo_db?schema=public"
# Managed Postgres (e.g. DigitalOcean) over TLS — auto-detected when DATABASE_URL has sslmode=require,
# or set DATABASE_SSL=true. Use DATABASE_SSL_CA for stricter verification with the provider CA cert.
# DATABASE_SSL=true
# DATABASE_SSL_CA=/path/to/ca-certificate.crt
JWT_SECRET=replace-with-long-random-string
CORS_ORIGIN=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_MODE=sandbox
# GBP for UK sandbox; use USD only if your sandbox business account is US-based
PAYPAL_CURRENCY=GBP

# DigitalOcean Spaces
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_REGION=ams3
DO_SPACES_BUCKET=fipo-documents
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_CDN_ENDPOINT=https://fipo-documents.ams3.cdn.digitaloceanspaces.com

# DocuSign
DOCUSIGN_ACCOUNT_ID=...
DOCUSIGN_INTEGRATION_KEY=...
DOCUSIGN_PRIVATE_KEY=...
DOCUSIGN_TEMPLATE_ID=...
DOCUSIGN_WEBHOOK_HMAC_SECRET=...

# Email (SMTP via nodemailer)
# Leave SMTP_HOST blank in development — emails are logged to the console instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="FIPO <noreply@fipo.co.uk>"
APP_BASE_URL=http://localhost:3000
