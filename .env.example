PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/fipo_microsite
# If Node fails with querySrv ECONNREFUSED on Windows, use public DNS for SRV:
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
# Or paste Atlas "standard connection string" (mongodb://...) instead of mongodb+srv://
JWT_SECRET=replace-with-long-random-string
CORS_ORIGIN=http://localhost:3000

# Optional seed defaults (seed-admin script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
