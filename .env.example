PORT=5000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fipo_db?schema=public"

# DigitalOcean managed Postgres (copy Connection string from Control Panel):
# DATABASE_URL="postgresql://doadmin:PASSWORD@your-cluster.db.ondigitalocean.com:25060/defaultdb?sslmode=require"
# No extra vars needed — sslmode=require is auto-detected. See:
# https://docs.digitalocean.com/products/databases/postgresql/how-to/connect/
#
# Optional verify-full (download CA cert from DO dashboard):
# DATABASE_URL="postgresql://doadmin:PASSWORD@your-cluster.db.ondigitalocean.com:25060/defaultdb?sslmode=verify-full"
# DATABASE_SSL_CA=/etc/ssl/certs/ca-certificate.crt
JWT_SECRET=replace-with-long-random-string
# Comma-separated browser origins allowed to call the API (must match where the Next app runs)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_MODE=sandbox
# GBP for UK sandbox; use USD only if your sandbox business account is US-based
PAYPAL_CURRENCY=GBP

# DigitalOcean Spaces
DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
DO_SPACES_REGION=ams3
DO_SPACES_BUCKET=fipo-documents
DO_SPACES_KEY=...
DO_SPACES_SECRET=...
DO_SPACES_CDN_ENDPOINT=https://fipo-documents.ams3.cdn.digitaloceanspaces.com

# DocuSign
DOCUSIGN_ACCOUNT_ID=...
DOCUSIGN_INTEGRATION_KEY=...
DOCUSIGN_PRIVATE_KEY=...
DOCUSIGN_TEMPLATE_ID=...
DOCUSIGN_WEBHOOK_HMAC_SECRET=...

# Email — Mailjet (https://www.mailjet.com)
# DigitalOcean blocks outbound SMTP port 587 → use EMAIL_TRANSPORT=mailjet-api on the server.
# Dashboard → Account settings → SMTP and SEND API keys (same keys for API mode)
# Verify sender under Domains and senders
#
# APP_BASE_URL=http://46.101.60.110
# CORS_ORIGIN=http://46.101.60.110
# EMAIL_TRANSPORT=mailjet-api
# SMTP_USER=your-mailjet-api-key
# SMTP_PASS=your-mailjet-secret-key
# EMAIL_FROM="FIPO <pankajtechcode@gmail.com>"
#
# Local dev: leave EMAIL_TRANSPORT unset and SMTP_HOST blank → [EMAIL:STUB] in console
EMAIL_TRANSPORT=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="FIPO <noreply@fipo.co.uk>"
APP_BASE_URL=http://localhost:3000
